FROM node:22-slim AS base
RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates curl git \
  && rm -rf /var/lib/apt/lists/* \
  && corepack enable

FROM base AS production
WORKDIR /app
RUN npm install --global paperclipai@latest
ENV NODE_ENV=production
EXPOSE 3100
CMD ["paperclipai", "run"]
