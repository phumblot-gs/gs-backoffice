FROM node:22-slim AS base
RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates curl git \
  && rm -rf /var/lib/apt/lists/* \
  && corepack enable

# -----------------------------------------------------------------------------
# Build the Fly Sprites sandbox-provider plugin and assemble a self-contained,
# production-only copy at a STABLE path. Paperclip's local-path plugin install
# references this path directly (no copy), and activation loads the worker from
# it on every boot — so the files are versioned with the image and a one-time
# `plugin install /opt/gs-plugins/plugin-fly-sprites` keeps it durable (record in
# RDS), with no EFS and no entrypoint change.
# -----------------------------------------------------------------------------
FROM base AS plugin-build
WORKDIR /repo
COPY . .
# Full workspace install (this build stage is throwaway — only the bundled dist is
# copied into the final image). A filtered install left @gs-backoffice/core without its
# devDeps (typescript/@types), so its tsc build failed with spurious "unknown" types.
# Then build the workspace deps (tsc → dist) BEFORE the esbuild bundlers, which resolve
# @gs-backoffice/* from their built dist (the bundlers inline them).
RUN pnpm install --frozen-lockfile \
  && pnpm --filter @gs-backoffice/core --filter @gs-backoffice/evt-client build \
  && pnpm --filter @gs-backoffice/sandbox-fly-sprites \
          --filter @gs-backoffice/agent-sandbox-mcp build
# Standalone bundle: built dist + manifest + its single prod dep (@paperclipai/plugin-sdk).
RUN mkdir -p /opt/gs-plugins/plugin-fly-sprites \
  && cp -r packages/sandbox-fly-sprites/dist /opt/gs-plugins/plugin-fly-sprites/dist \
  && node -e "const p=require('/repo/packages/sandbox-fly-sprites/package.json'); require('fs').writeFileSync('/opt/gs-plugins/plugin-fly-sprites/package.json', JSON.stringify({name:p.name,version:p.version,type:p.type,private:true,paperclipPlugin:p.paperclipPlugin,dependencies:p.dependencies}, null, 2))" \
  && cd /opt/gs-plugins/plugin-fly-sprites \
  && npm install --omit=dev --no-package-lock
# Standalone bundle for the agent-facing sandbox MCP server (stdio). NOT a Paperclip
# plugin — the agent's `claude` process launches it via --mcp-config; it proxies tool
# calls to the deployed sandbox plugin's executeTool route. Vendor it + its prod deps.
RUN mkdir -p /opt/gs-agent-tools/agent-sandbox-mcp \
  && cp -r apps/agent-sandbox-mcp/dist /opt/gs-agent-tools/agent-sandbox-mcp/dist \
  && node -e "const p=require('/repo/apps/agent-sandbox-mcp/package.json'); require('fs').writeFileSync('/opt/gs-agent-tools/agent-sandbox-mcp/package.json', JSON.stringify({name:p.name,version:p.version,type:p.type,private:true,bin:p.bin,dependencies:p.dependencies}, null, 2))" \
  && cd /opt/gs-agent-tools/agent-sandbox-mcp \
  && npm install --omit=dev --no-package-lock
# MCP config that points `claude` at the baked stdio server. Attach to an agent via
# adapterConfig.extraArgs: ["--mcp-config", "/opt/gs-agent-tools/mcp-config.json"].
RUN printf '%s\n' '{"mcpServers":{"gs-sandbox":{"command":"node","args":["/opt/gs-agent-tools/agent-sandbox-mcp/dist/index.js"]}}}' \
  > /opt/gs-agent-tools/mcp-config.json
# Bake the RBAC config so the bridge can resolve the per-repo notify scope
# (repos → scope) for PR-review Google Chat notifications. Synced with RBAC at deploy.
COPY config/rbac.json /opt/gs-agent-tools/rbac.json

FROM base AS production
WORKDIR /app
RUN npm install --global paperclipai@2026.609.0 @anthropic-ai/claude-code@latest
# Surgical patch: forward the sandbox tools' secrets (SPRITES_TOKEN, SANDBOX_GITHUB_*)
# to the plugin worker via ADAPTER_ENV_PASSTHROUGH, and gate that passthrough on
# `agent.tools.register` (the SDK's other secret paths are unavailable to tools in
# 2026.609.0; the env driver that previously satisfied the gate is retired).
# Anchored + idempotent.
COPY docker/patches/patch-paperclip-plugin-env.mjs /tmp/patch-paperclip-plugin-env.mjs
RUN node /tmp/patch-paperclip-plugin-env.mjs && rm -f /tmp/patch-paperclip-plugin-env.mjs
# Surgical patch: raise the executeTool host→worker RPC timeout from 30s to the
# 15min host max, so long-running sandbox tools (provision + clone + run / Claude)
# are not killed at 30s. Anchored + idempotent.
COPY docker/patches/patch-paperclip-tool-timeout.mjs /tmp/patch-paperclip-tool-timeout.mjs
RUN node /tmp/patch-paperclip-tool-timeout.mjs && rm -f /tmp/patch-paperclip-tool-timeout.mjs
RUN mkdir -p /paperclip && chown node:node /paperclip
# Bake the self-contained plugin at a stable path (outside the instance plugins
# dir, so Paperclip references it without managing/cleaning it).
COPY --from=plugin-build --chown=node:node /opt/gs-plugins /opt/gs-plugins
# Bake the agent-facing sandbox MCP server + its mcp-config at a stable path.
COPY --from=plugin-build --chown=node:node /opt/gs-agent-tools /opt/gs-agent-tools
COPY --chown=node:node docker/paperclip-entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh
ENV NODE_ENV=production
ENV PAPERCLIP_HOME=/paperclip
ENV HOST=0.0.0.0
USER node
EXPOSE 3100
ENTRYPOINT ["/entrypoint.sh"]
