  },
  "dependencies": {
    "@paperclipai/plugin-sdk": "2026.609.0",
    "@fly/sprites": "0.0.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
