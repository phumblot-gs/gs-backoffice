{
  "name": "@gs-backoffice/sandbox-fly-sprites",
  "version": "0.1.0",
  "private": true,
  "description": "Paperclip sandbox-provider plugin: runs agent code in Fly Sprites (Firecracker microVMs, EU).",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js"
  },
  "scripts": {
