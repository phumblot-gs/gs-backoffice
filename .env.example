# =============================================================================
# gs-backoffice — Environment Variables
# Copy to .env and fill in your values
# =============================================================================

# --- Paperclip ---
DATABASE_URL=postgresql://paperclip:paperclip@localhost:5432/paperclip
PAPERCLIP_PORT=3100
BETTER_AUTH_SECRET=dev-secret-change-in-production

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- EVT (gs-stream-events) ---
EVT_API_URL=http://localhost:4000
EVT_API_KEY=dev-evt-key

# --- MCP Auth Tokens ---
# NOTION_MCP_TOKEN=
# ASANA_MCP_TOKEN=
# HUBSPOT_MCP_TOKEN=
# HYPERLINE_MCP_TOKEN=
# GOOGLE_DRIVE_MCP_TOKEN=
# GMAIL_MCP_TOKEN=
# LINEAR_MCP_TOKEN=

# --- Direct APIs ---
# PENNYLANE_API_TOKEN=
