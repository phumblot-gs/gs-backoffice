# --- Claude Code (Methods Officer) ---
# CLAUDE_CODE_BINARY=claude
# CLAUDE_CODE_ALLOWED_TOOLS=Read,Write,Edit,Bash(pnpm *),Bash(git *)

# --- Monitoring ---
# SENTRY_DSN=
NODE_ENV=development
