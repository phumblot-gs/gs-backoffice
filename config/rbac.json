{
  "groups": {
    "Management Team": {
      "services": {
        "notion": { "actions": ["read"], "scopes": ["*"] },
        "paperclip": {
          "actions": ["read", "create_ticket", "update_ticket"],
          "scopes": ["*"]
        }
      },
      "workflows": ["*"]
    },
    "Sales": {
      "services": {
        "notion": {
          "actions": ["read"],
          "scopes": ["Commercial", "Général", "Comptabilité - Finance"]
        },
        "paperclip": {
          "actions": ["read", "create_ticket"],
          "scopes": ["sales"]
        }
      },
      "workflows": ["register_contract", "prospect_brief"]
    },
    "Customer Success": {
      "services": {
        "notion": {
          "actions": ["read"],
          "scopes": ["Customer Success", "Commercial", "Général"]
        },
        "paperclip": {
          "actions": ["read", "create_ticket"],
          "scopes": ["customer_success"]
        }
      },
      "workflows": ["client_issue", "onboarding"]
    },
    "DevOps": {
      "services": {
        "notion": {
          "actions": ["read"],
          "scopes": ["Engineering", "DevOps", "Général"]
        },
        "paperclip": { "actions": ["read"], "scopes": ["engineering"] }
      },
      "workflows": ["bug_report", "feature_request"]
    },
    "DevProduct": {
      "services": {
        "notion": {
          "actions": ["read"],
          "scopes": ["Engineering", "Product", "Général"]
        },
        "paperclip": {
          "actions": ["read", "create_ticket"],
          "scopes": ["engineering", "product"]
        }
      },
      "workflows": ["bug_report", "feature_request"]
    },
    "All Users": {
      "services": {
        "notion": { "actions": ["read"], "scopes": ["Général"] },
        "paperclip": { "actions": ["read"], "scopes": ["general"] }
      },
      "workflows": []
    }
  }
}
